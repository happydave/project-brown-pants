// The trivial core content pack (WI 547) — the first authored asset pack.
// Real physical quantities only; balance scalars live in the settings /
// override layers (WIs 548/549), never here.
#![enable(implicit_some)]
(
    format: 1,
    id: "core",
    version: "0.1.0",
    records: [
        // Abstract base: the common liquid-fuel engine physics. Not content —
        // an inheritance target only.
        Device((
            id: "engine_base",
            abstract: true,
            class: Engine,
            exhaust_velocity: 3200.0, // m/s (Isp ≈ 326 s)
        )),
        // Concrete variant: inherits the base's exhaust velocity, sets its own
        // size (mass flow) and bulk density.
        Device((
            id: "lf_engine_small",
            parent: "engine_base",
            density: 3000.0,      // kg/m³ (WI 615 cell-scaled mass shape)
            max_mass_flow: 1.5,   // kg/s ⇒ ~4.8 kN max thrust
        )),
        // A small propellant tank (WI 550): the capacity the scenario
        // director's assembly draws per Tank device on the starting craft.
        // Sized to the starter scale: the small engine lifts ~370 kg all-up
        // (after the example scalars), so the starter tank stays light.
        Device((
            id: "fuel_tank_small",
            class: Tank,
            density: 400.0,  // kg/m³ (empty shell — propellant is separate)
            capacity: 100.0, // kg propellant per tank
        )),
        // The sounding-rocket engine (WI 739): the migrated flight-family
        // scenes' engine as a catalog record — 3000 m/s × 70 kg/s ⇒ ~210 kN,
        // TWR ≈ 1.6 on the sounding-rocket blueprint. Authored standalone
        // (not off engine_base): these are the scenes' physical values,
        // carried over unchanged.
        Device((
            id: "lf_engine_medium",
            class: Engine,
            density: 3000.0,          // kg/m³
            exhaust_velocity: 3000.0, // m/s (Isp ≈ 306 s)
            max_mass_flow: 70.0,      // kg/s ⇒ ~210 kN max thrust
        )),
        // The sounding-rocket tank (WI 739): the scenes' 5000 kg propellant
        // load as a per-tank capacity.
        Device((
            id: "fuel_tank_medium",
            class: Tank,
            density: 400.0,   // kg/m³
            capacity: 5000.0, // kg propellant per tank
        )),
        // A structural material — the payload is the sim's real Material shape
        // (density + strength + the thermal quad).
        Material((
            id: "aluminium",
            density: 2700.0,        // kg/m³
            strength: 3.1e8,        // Pa
            specific_heat: 900.0,   // J·kg⁻¹·K⁻¹
            conductivity: 237.0,    // W·m⁻¹·K⁻¹
            emissivity: 0.09,
            max_temp: 900.0,        // K (≈ melting)
        )),
        // Glass (WI 821) — the transparent structural material: brittle, a poor
        // conductor, softens near 1000 K. Mirrors the sim's Material::GLASS.
        Material((
            id: "glass",
            density: 2500.0,       // kg/m³
            strength: 4.0e7,       // Pa (brittle — the weakest structural material)
            specific_heat: 840.0,  // J·kg⁻¹·K⁻¹
            conductivity: 1.0,     // W·m⁻¹·K⁻¹
            emissivity: 0.90,
            max_temp: 1000.0,      // K (softening)
        )),
        // A resource.
        Resource((
            id: "liquid_fuel",
            density: 800.0,  // kg/m³
            tradable: true,
        )),
    ],
)
