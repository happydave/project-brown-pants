// The canonical bodies, authored as recipes (WI 884) — the single authored
// source of canonical body configuration. Embedded in the sim crate at compile
// time and resolved through the ordinary content merge-ladder; the old
// `BodyAsset::earthlike`/`earthlike_ice_age` constructors and the
// `bodygen::default_bands` literals resolve from here.
//
// Values mirror the engine physics constants digit-for-digit
// (`CentralBody::EARTHLIKE`, `Rotation::EARTHLIKE`, `FluidMedium::EARTHLIKE`);
// a drift-guard test pins the two forever. The ice-age offset is the WI-875
// derivation (guaranteed-frozen 248 K minus the ISA surface ambient 288.15 K),
// authored as its value; a test pins it to `EARTHLIKE_ICE_AGE_OFFSET`.
//
// The shaped records (moon / rocky / ocean) carry the archetype parameter
// bands that used to live in `bodygen::generate`'s match arms (WI 883 lifted
// them to data; this pack is now their only source). They are concrete (seed 0)
// so they resolve into the catalog, where their retained bands drive
// `bodygen::generate` at arbitrary seeds — and they are legal parents for
// future authored children.
#![enable(implicit_some)]
(
    format: 2,
    id: "sim-canonical-bodies",
    version: "1",
    records: [
        // The medium's derived fields are pin-or-derive (WI 886): an authored
        // value below is a **pin** (held exactly), an absent one is computed by
        // its relation. Since **WI 887** earthlike's two legacy incoherences
        // are un-pinned and **derive**: `gravity` = μ/R² ≈ 9.8542 (was 9.81)
        // and `atmosphere_scale_height` = R·T/(M·g) ≈ 8394.6 m (was 8500),
        // with `mean_molar_mass` (dry air; digits must match
        // `fluid::EARTHLIKE_MEAN_MOLAR_MASS` — weld-tested) supplying the gas
        // relation. `ocean_surface_pressure` also derives (continuity). The
        // two remaining pins are **intentional anchors, not incoherences**:
        // `atmosphere_temperature` 288.15 is the WI-875 ISA anchor (routing it
        // through a C1 insolation chain is future authoring), and
        // `atmosphere_surface_density` 1.225 is ISA-exact authored intent
        // (coherent with the ideal-gas relation to 2e-5 relative).
        BodyRecipe((
            id: "earthlike",
            name: "Earth-like",
            mu: 3.986e14,
            radius: 6360000.0,
            rotation_period: 86164.0905,
            atmosphere_surface_density: 1.225,    // pin (intentional ISA anchor)
            atmosphere_surface_pressure: 101325.0,
            mean_molar_mass: 0.0289644,
            ocean_surface_density: 1025.0,
            ocean_density_gradient: 0.0,
            atmosphere_temperature: 288.15,       // pin (WI-875 ISA anchor)
            ocean_temperature: 290.0,
            surface_seed: 0,
        )),
        // The identical body — same physics, same terrain seed — carrying the
        // explicit cold classifier offset (248 - 288.15; WI 875) that pushes its
        // surface below the ocean-freeze point.
        BodyRecipe((
            id: "earthlike-ice-age",
            name: "Earth-like (Ice Age)",
            parent: "earthlike",
            surface_temperature_offset: -40.15,
        )),
        // Archetypes (WI 889): bands express the drawn INDEPENDENT set — the
        // medium (temperature, density, scale height) is DERIVED via the same
        // `body_derive` relations the fixed recipes use, never drawn directly.
        // Earth anchors: S ≈ 1361 W/m², A ≈ 0.29, ΔT_greenhouse ≈ 33 K,
        // M = 0.0289644 kg/mol. Derived spans at the band-box corners (noted
        // per shape below) approximate the retired direct bands; density and
        // scale-height spans come out wider than the old direct bands — that
        // is the point of derivation (a light atmosphere on a low-g world IS
        // puffy), and populations shift under this deliberate values bump.
        BodyRecipe((
            id: "moon",
            name: "Moon",
            shape: moon,
            surface_seed: 0,
            radius_min: 2.0e5, radius_max: 2.0e6,
            gravity_min: 0.5, gravity_max: 3.0,
            rotation_period_min: 20000.0, rotation_period_max: 200000.0,
            // Airless: T_surf = T_eq(S, A), greenhouse zero. Corner span
            // ~155 K (S=200, A=0.35) to ~335 K (S=3000, A=0.05) — replaces
            // the old literal 200 K with sun-near/sun-far variety.
            nominal_insolation_min: 200.0, nominal_insolation_max: 3000.0,
            bond_albedo_min: 0.05, bond_albedo_max: 0.35,
        )),
        BodyRecipe((
            id: "rocky",
            name: "Rocky Planet",
            shape: rocky_planet,
            surface_seed: 0,
            radius_min: 2.5e6, radius_max: 8.0e6,
            gravity_min: 3.0, gravity_max: 12.0,
            rotation_period_min: 20000.0, rotation_period_max: 200000.0,
            atmosphere_surface_pressure_min: 50000.0, atmosphere_surface_pressure_max: 150000.0,
            // T_surf corner span ~219.5 K (S=800, A=0.4, ΔT=5) to ~338.5 K
            // (S=2000, A=0.1, ΔT=40) — approximates the retired direct
            // 220–300 K band. Derived density ~0.36–3.7 kg/m³ (was 0.2–2.0);
            // derived scale height ~3.4–47 km (was 5–12 km).
            nominal_insolation_min: 800.0, nominal_insolation_max: 2000.0,
            bond_albedo_min: 0.1, bond_albedo_max: 0.4,
            greenhouse_delta_t_min: 5.0, greenhouse_delta_t_max: 40.0,
            mean_molar_mass_min: 0.02, mean_molar_mass_max: 0.045,
        )),
        BodyRecipe((
            id: "ocean",
            name: "Ocean World",
            shape: ocean_world,
            surface_seed: 0,
            radius_min: 3.0e6, radius_max: 9.0e6,
            gravity_min: 5.0, gravity_max: 12.0,
            rotation_period_min: 20000.0, rotation_period_max: 200000.0,
            atmosphere_surface_pressure_min: 80000.0, atmosphere_surface_pressure_max: 180000.0,
            // T_surf corner span ~281.4 K (S=1400, A=0.3, ΔT=25) to ~334.2 K
            // (S=2000, A=0.15, ΔT=40): every corner clears the 254 K ocean
            // freeze gate with margin, so the canonical ocean world always
            // keeps its liquid ocean (the gating mechanism is uniform, but
            // these bands never trip it). Derived density ~0.52–2.3 kg/m³
            // (was 0.5–2.5); derived scale height ~6.5–31 km (was 6–12 km).
            nominal_insolation_min: 1400.0, nominal_insolation_max: 2000.0,
            bond_albedo_min: 0.15, bond_albedo_max: 0.3,
            greenhouse_delta_t_min: 25.0, greenhouse_delta_t_max: 40.0,
            mean_molar_mass_min: 0.018, mean_molar_mass_max: 0.03,
            ocean_surface_density_min: 950.0, ocean_surface_density_max: 1100.0,
            ocean_temperature_min: 275.0, ocean_temperature_max: 300.0,
        )),
    ],
)
